# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=sephora_user
POSTGRES_PASSWORD=changeme_123
POSTGRES_DB=sephora_dw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


# ─── Groq API (análisis de sentimiento) ─────────────────────
# Regístrate gratis en  https://console.groq.com/ → Settings → Api Keys
GROQ_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de reseñas a analizar via API (recomendado: 500-1000)
SENTIMENT_SAMPLE_SIZE=500

# Pausa entre llamadas en segundos (evita rate limiting)
SENTIMENT_REQUEST_DELAY=0.3

# Timeout por llamada en segundos
SENTIMENT_TIMEOUT=30

# Ruta del caché local (evita re-consultar la API en cada corrida)
SENTIMENT_CACHE_PATH=data/processed/sentiment_cache.csv

# ─── API de tipo de cambio ────────────────────────────────────────────────────
# URL de la API gratuita open.er-api.com (no requiere clave)
EXCHANGE_API_URL=https://v6.exchangerate-api.com/v6/latest/USD

# Timeout en segundos para peticiones HTTP a la API
EXCHANGE_API_TIMEOUT=10

# Tasa de fallback (CLP por 1 USD) si la API no está disponible
# Actualiza este valor periódicamente con el tipo de cambio real
FALLBACK_USD_CLP=950.0

# ─── Configuración general ────────────────────────────────────────────────────
LOG_LEVEL=INFO
